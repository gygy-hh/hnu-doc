    "/search": {
      "get": {
        "summary": "搜索科目",
        "deprecated": false,
        "description": "",
        "tags": [],
        "parameters": [
          {
            "name": "key",
            "in": "query",
            "description": "关键字，没有关键字的话",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "typ",
            "in": "query",
            "description": "见 Document 的 typ，可以传递多个",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "page_size",
            "in": "query",
            "description": "每页的数量，默认为 10",
            "required": false,
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "page",
            "in": "query",
            "description": "第几页，默认为 1",
            "required": false,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": {
                      "type": "string",
                      "title": "请求的状态信息",
                      "description": "成功则为 OK，失败则为相应的错误代码。失败时 msg 保存可选的可读信息，data 里也可存放附加的字段。"
                    },
                    "data": {
                      "type": "object",
                      "properties": {
                        "subjects": {
                          "type": "array",
                          "items": {
                            "type": "object",
                            "properties": {
                              "name": {
                                "type": "string",
                                "title": "科目名称"
                              },
                              "year": {
                                "type": "integer",
                                "title": "最新年份",
                                "nullable": true
                              },
                              "count": {
                                "type": "integer",
                                "title": "包含试卷数量"
                              }
                            },
                            "required": [
                              "count",
                              "name",
                              "year"
                            ]
                          },
                          "minItems": 5,
                          "maxItems": 15
                        },
                        "pages": {
                          "type": "integer",
                          "title": "总页数"
                        }
                      },
                      "required": [
                        "subjects",
                        "pages"
                      ]
                    },
                    "msg": {
                      "type": "string",
                      "title": "错误信息",
                      "nullable": true
                    }
                  },
                  "required": [
                    "status",
                    "data"
                  ]
                }
              }
            },
            "headers": {}
          }
        },
        "security": []
      }
    },
