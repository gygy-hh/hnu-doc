                    },
                    "data": {
                      "type": "string",
                      "title": "负载数据",
                      "description": "下载链接"
                    },
                    "msg": {
                      "type": "string",
                      "title": "错误信息",
                      "nullable": true
                    }
                  },
                  "required": [
