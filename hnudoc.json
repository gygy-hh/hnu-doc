    "/document/download": {
      "post": {
        "summary": "下载试卷",
        "deprecated": false,
        "description": "使用工作量证明来防止被攻击。\n\n服务端下发 ticket 值和 zero 值，客户端需要在 ticket 值后面接任意字符串来确保计算出来的 hash 值的前 zero 位为 0.",
        "tags": [],
        "parameters": [
          {
            "name": "id",
            "in": "query",
            "description": "要下载试卷的 id",
            "required": false,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": {
                      "type": "string",
                      "title": "请求的状态信息",
                      "description": "成功则为 OK，失败则为相应的错误代码。失败时 msg 保存可选的可读信息，data 里也可存放附加的字段。"
                    },
                    "data": {
                      "type": "object",
                      "properties": {
                        "ticket": {
                          "type": "string"
                        },
                        "zero": {
                          "type": "integer"
                        }
                      },
                      "title": "负载数据",
                      "required": [
                        "ticket",
                        "zero"
                      ]
                    },
                    "msg": {
                      "type": "string",
                      "title": "错误信息",
                      "nullable": true
                    }
                  },
                  "required": [
                    "status"
                  ]
                }
              }
            },
            "headers": {}
          }
        },
        "security": []
      },
      "get": {
        "summary": "获取试卷下载链接",
        "deprecated": false,
        "description": "可能发生的错误：\n\n* POW_KEY_INVALID：计算的 key 是错误的。同时原来的 ticket 也失效，需要请求 POST /document/download 获得新的 ticket。",
        "tags": [],
        "parameters": [
          {
            "name": "ticket",
            "in": "query",
            "description": "通过 POST /document/download 获得的 ticket 值",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "key",
            "in": "query",
            "description": "满足条件的字符串。字符串的前缀需要是 ticket",
            "required": false,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "",
            "content": {
